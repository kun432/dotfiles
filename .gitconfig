[user]
	email = k.shimizu@8d1w.com
	name = Kuniaki Shimizu
[color]
	ui = auto
[alias]
	co = checkout
	ci = commit
	br = branch
	ad = add
	st = status
	lo = log
	tr = log --graph --date=short --pretty='format:%C(yellow)%h%Creset %s %Cgreen(%an)%Creset %Cred%d%Creset'
	sh = show
[push]
	default = simple
